{
    "name": "@cjaye/react-meta-state",
    "version": "0.1.0",
    "description": "",
    "keywords": [],
    "license": "MIT",
    "author": "Charles Jaye",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/c-jaye/react-meta-state.git"
    },
    "private": false,
    "type": "module",
    "scripts": {
        "clean": "pnpx del-cli@latest --force \"**/package-lock.json\" \"**/storybook-static\" \"**/test-results.xml\" \"**/debug-storybook.log\" \"**/build-storybook.log\" \"**/node_modules\" \"**/dist\" \"**/.husky/_\" \"**/chromatic-build-*.xml\" \"**/verdaccio/storage\" \"**/verdaccio/htpasswd\" \"**/verdaccio/config.yaml\"",
        "prepare": "pnpm run prepare:husky && pnpm run prepare:ownership",
        "prepare:husky": "husky || true",
        "prepare:ownership": "chmod +x .husky/pre-push",
        "postinstall": "pnpm run postinstall:playwright && pnpm run postinstall:verdaccio",
        "postinstall:playwright": "pnpx playwright install --with-deps",
        "postinstall:verdaccio": "chmod +x verdaccio/init verdaccio/login",
        "lint": "tsc -b && pnpm run lint:check",
        "lint:check": "pnpm eslint .",
        "lint:fix": "pnpm eslint . --fix",
        "test": "pnpm run lint && pnpm run test:unit",
        "test:unit": "vitest --no-watch",
        "build": "pnpm run test && pnpm run build:bundle",
        "build:storybook": "storybook build -c ./playground/.storybook",
        "build:bundle": "unbuild",
        "dev": "pnpm run build:bundle && concurrently \"pnpm run dev:storybook\" \"pnpm run dev:verdaccio\"",
        "dev:storybook": "storybook dev -p 6006 -c ./playground/.storybook",
        "dev:verdaccio": "verdaccio --listen 30333",
        "prepublishOnly": "del-cli --force \"**/dist\" && pnpm run build",
        "publish:verdaccio": "verdaccio/init || true && verdaccio/login && pnpm publish --access public --tag latest --no-git-checks --registry http://localhost:30333",
        "publish:chromatic": "pnpx chromatic@latest",
        "publish:npm": "pnpm publish --access public --tag latest --no-git-checks --registry registry.npmjs.org"
    },
    "packageManager": "pnpm@10.31.0",
    "engines": {
        "node": "^24.15.0"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs",
            "default": "./dist/index.mjs"
        },
        "./addons/state": {
            "types": "./dist/addons/state/index.d.mts",
            "import": "./dist/addons/state/index.mjs",
            "require": "./dist/addons/state/index.cjs",
            "default": "./dist/addons/state/index.mjs"
        },
        "./addons/state/preview": {
            "types": "./dist/addons/state/preview.d.mts",
            "import": "./dist/addons/state/preview.mjs",
            "require": "./dist/addons/state/preview.cjs",
            "default": "./dist/addons/state/preview.mjs"
        },
        "./addons/state/manager": {
            "types": "./dist/addons/state/manager.d.mts",
            "import": "./dist/addons/state/manager.mjs",
            "require": "./dist/addons/state/manager.cjs",
            "default": "./dist/addons/state/manager.mjs"
        },
        "./addons/breakpoints": {
            "types": "./dist/addons/breakpoints/index.d.mts",
            "import": "./dist/addons/breakpoints/index.mjs",
            "require": "./dist/addons/breakpoints/index.cjs",
            "default": "./dist/addons/breakpoints/index.mjs"
        },
        "./addons/breakpoints/preview": {
            "types": "./dist/addons/breakpoints/preview.d.mts",
            "import": "./dist/addons/breakpoints/preview.mjs",
            "require": "./dist/addons/breakpoints/preview.cjs",
            "default": "./dist/addons/breakpoints/preview.mjs"
        },
        "./addons/breakpoints/manager": {
            "types": "./dist/addons/breakpoints/manager.d.mts",
            "import": "./dist/addons/breakpoints/manager.mjs",
            "require": "./dist/addons/breakpoints/manager.cjs",
            "default": "./dist/addons/breakpoints/manager.mjs"
        },
        "./scss/*": "./dist/scss/*.scss",
        "./package.json": "./package.json"
    },
    "os": [
        "darwin",
        "linux",
        "win32"
    ],
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1"
    },
    "peerDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "storybook": "^10.3.5"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.1.1",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-designs": "^11.1.3",
        "@storybook/addon-vitest": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^24.12.2",
        "@types/opentype.js": "^1.3.9",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react-swc": "^4.3.0",
        "@vitest/browser": "^4.1.4",
        "@vitest/browser-playwright": "^4.1.4",
        "@vitest/coverage-v8": "^4.1.4",
        "chromatic": "^16.3.0",
        "classnames": "^2.5.1",
        "concurrently": "^9.2.1",
        "del-cli": "^7.0.0",
        "dotenv": "^17.4.2",
        "eslint": "^9.39.4",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import-x": "^4.16.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-storybook": "10.3.5",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "opentype.js": "^1.3.4",
        "playwright": "^1.59.1",
        "sass-embedded": "^1.99.0",
        "storybook": "^10.3.5",
        "tinyglobby": "^0.2.16",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.58.1",
        "unbuild": "^3.6.1",
        "verdaccio": "^6.5.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.4"
    }
}
